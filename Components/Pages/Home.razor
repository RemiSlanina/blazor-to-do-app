</section>

<hr>
<h2>debugging</h2>
<p>@taskInput | Tasks: @string.Join(", ", tasks.Select(t => t.Text))</p>
<p>progress: @progress</p>
<hr>


<style>
    .completed { color: grey; text-decoration: line-through; }
    .pending { color: black; text-decoration: none;}
</style>


@code {
    @* private bool filterCompletedTasks = false;  *@
    @* private bool filterTasks = true;  *@
    public enum TaskFilter {
        ViewAll, 
        ViewPending, 
        ViewCompleted
    }
    private TaskFilter filterTasks { get; set; } = TaskFilter.ViewAll; 
    private string taskInput { get; set; } = ""; 
    private List<TaskItem> tasks { get; set; } = new(); 
    private int _progress; 
    private int progress { 
        get {
            if (tasks.Count == 0) return 0; 
            int tasksCompleted = tasks.Count(t => t.IsCompleted); 
            _progress = (tasksCompleted * 100) / tasks.Count; 
            return _progress; 
        }
        @* set => _progress = value; // actually, do not set  *@
    }
    private class TaskItem {
        public string Text { get; set; } = ""; 
        public bool IsCompleted { get; set; }
    }

    @* -------------------------------------------------- *@ 

    private IEnumerable<TaskItem> FilteredTasks => filterTasks switch 
        {
            TaskFilter.ViewAll => tasks, 
            TaskFilter.ViewCompleted => tasks.Where(t => t.IsCompleted), 
            TaskFilter.ViewPending => tasks.Where(t => !t.IsCompleted), 
            _ => tasks
        };

    private async Task AddTask() {
        if (!string.IsNullOrWhiteSpace(taskInput)) {
            tasks.Add(new TaskItem { Text = taskInput, IsCompleted = false }); 
            // TO DO save to localStorage
            await JS.InvokeVoidAsync("localStorage.setItem", "tasks", JsonSerializer.Serialize(tasks)); 
            taskInput = ""; 
            StateHasChanged(); 
        }
    }

    private async Task ToggleComplete(TaskItem task) {
        task.IsCompleted = ! task.IsCompleted; 
        await JS.InvokeVoidAsync("localStorage.setItem", "tasks", JsonSerializer.Serialize(tasks)); 
        StateHasChanged(); 
    }
    private async Task DeleteTask(TaskItem task) {
        // delete 
        tasks.Remove(task); 
        // TO DO save to localStorage
        await JS.InvokeVoidAsync("localStorage.setItem", "tasks", JsonSerializer.Serialize(tasks)); 
        StateHasChanged(); 
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
           string? json = await JS.InvokeAsync<string?>("localStorage.getItem", "tasks");
            if (json != null) {
                try {
                    tasks = JsonSerializer.Deserialize<List<TaskItem>>(json) ?? new(); 
                } catch (JsonException) {
                    tasks = new(); // new list if json is corrupted 
                    await JS.InvokeVoidAsync("localStorage.setItem", "tasks", JsonSerializer.Serialize(tasks));
                }
                
            }
            StateHasChanged(); 
        }
        
    }  

}