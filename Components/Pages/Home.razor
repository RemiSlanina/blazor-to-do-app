@page "/"
@using System.Threading.Tasks
@using System.Text.Json
@using Microsoft.AspNetCore.Mvc
@rendermode InteractiveServer 
@inject IJSRuntime JS 

<PageTitle>Home</PageTitle>

<h1>To Do App</h1>

<section class="input-section">
    <p>Please enter a task below to get going.</p>
    <label for="text-input">Task</label> 
    <input @bind="taskInput" placeholder="Enter a task" type="text" name="text-input" id="text-input">
    <button class="btn btn-outline-secondary" @onclick="AddTask">Add</button>
</section>

<section class="output-section">
    <div class="progress-container">
        <div class="progress">
            <div class="progress-bar" role="progressbar" style="width: @progress%" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
    </div>
    <ul class="task-list">
        @foreach (TaskItem task in tasks)
        {
            <li class="task-item">
                <p> <span class="@(task.IsCompleted ? "completed" : "pending")"> @task.Text</span></p>
                <div class="task-actions">
                        <button class="btn btn-outline-danger tskbtn" @onclick="() => DeleteTask(task)">Delete ✖️</button> 
                        <button class="btn btn-outline-dark tskbtn" @onclick="() => ToggleComplete(task)">Toggle completed ✔️</button>
                    </div>
            </li>
        }
    </ul>
</section>

<hr>
<h2>debugging</h2>
<p>@taskInput | Tasks: @string.Join(", ", tasks.Select(t => t.Text))</p>
<p>progress: @progress</p>
<hr>


<style>
    .completed { color: grey; text-decoration: line-through; }
    .pending { color: black; text-decoration: none;}
</style>


@code {
    private string taskInput { get; set; } = ""; 
    private List<TaskItem> tasks { get; set; } = new(); 
    private int _progress; 
    private int progress { 
        get {
            if (tasks.Count == 0) return 0; 
            int tasksCompleted = tasks.Count(t => t.IsCompleted); 
            _progress = (tasksCompleted * 100) / tasks.Count; 
            return _progress; 
        }
        @* set => _progress = value; // actually, do not set  *@
    }
    private class TaskItem {
        public string Text { get; set; } = ""; 
        public bool IsCompleted { get; set; }
    }


    private async Task AddTask() {
        if (!string.IsNullOrWhiteSpace(taskInput)) {
            tasks.Add(new TaskItem { Text = taskInput, IsCompleted = false }); 
            // TO DO save to localStorage
            await JS.InvokeVoidAsync("localStorage.setItem", "tasks", JsonSerializer.Serialize(tasks)); 
            taskInput = ""; 
            StateHasChanged(); 
        }
    }

    private async Task ToggleComplete(TaskItem task) {
        task.IsCompleted = ! task.IsCompleted; 
        await JS.InvokeVoidAsync("localStorage.setItem", "tasks", JsonSerializer.Serialize(tasks)); 
        StateHasChanged(); 
    }
    private async Task DeleteTask(TaskItem task) {
        // delete 
        tasks.Remove(task); 
        // TO DO save to localStorage
        await JS.InvokeVoidAsync("localStorage.setItem", "tasks", JsonSerializer.Serialize(tasks)); 
        StateHasChanged(); 
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
           string? json = await JS.InvokeAsync<string?>("localStorage.getItem", "tasks");
            if (json != null) {
                try {
                    tasks = JsonSerializer.Deserialize<List<TaskItem>>(json) ?? new(); 
                } catch (JsonException) {
                    tasks = new(); // new list if json is corrupted 
                    await JS.InvokeVoidAsync("localStorage.setItem", "tasks", JsonSerializer.Serialize(tasks));
                }
                
            }
            StateHasChanged(); 
        }
        
    }  

}