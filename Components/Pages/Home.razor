@page "/"
@using System.Threading.Tasks
@using System.Text.Json
@using Microsoft.AspNetCore.Mvc
@rendermode InteractiveServer 
@using BlazorToDoApp.Models 
@inject IJSRuntime JS 

<PageTitle>To Do App</PageTitle>

<h1>To Do App</h1>
@* User Input *@
<section class="input-section">
    <p>Please enter a task below to get going.</p>
    <label for="text-input">Add New Task</label> 
    <input @oninput="e => taskInput = e.Value?.ToString() ?? string.Empty" @onkeydown="HandleKeyPress" class="form-control" placeholder="Enter a task" type="text" name="text-input" id="text-input">
    <button class="btn btn-outline-secondary" @onclick="AddTask">Add Task</button><br />
    
    <label for="filter-tasks">Filter Tasks</label>
    <select @bind="filterTasks" class="form-select" name="filter-tasks" id="filter-tasks">
    <option value="ViewAll">View All Tasks</option>
    <option value="ViewPending">View Pending</option>
    <option value="ViewCompleted">View Completed</option>
    </select>
</section>

<section class="output-section">
    @* Show Progress in Progress Bar *@
    <div class="progress-container">
        <label for="progress-bar">Task Completion: @progress%</label>
        <div class="progress">
            <div class="progress-bar" role="progressbar" style="width: @progress%" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
    </div>
   
   @* Show Task List + actions *@
    <ul class="task-list">
        @foreach (TaskItem task in FilteredTasks)
        {
            <li class="task-item">
                <p> <span class="@(task.IsCompleted ? "completed" : "pending")"> @task.Text</span></p>
                <div class="task-actions">
                        <button class="btn btn-outline-danger tskbtn" @onclick="() => DeleteTask(task)">Delete ✖️</button> 
                        <button class="btn btn-outline-dark tskbtn" @onclick="() => ToggleComplete(task)">Toggle completed ✔️</button>
                    </div>
            </li>
        }
    </ul>
</section>

@* 
<hr>
<h2>debugging</h2>
<p>@taskInput | Tasks: @string.Join(", ", tasks.Select(t => t.Text))</p>
<p>progress: @progress | Filter: @filterTasks</p>
<hr>
 *@

<style>
    .completed { color: grey; text-decoration: line-through; }
    .pending { color: black; text-decoration: none;}
</style>


@code {
    public enum TaskFilter {
        ViewAll, 
        ViewPending, 
        ViewCompleted
    }
    private TaskFilter filterTasks { get; set; } = TaskFilter.ViewAll; 
    private string taskInput { get; set; } = ""; 
    // task list is less rigid than array 
    private List<TaskItem> tasks { get; set; } = new(); 
    private int progress { // calculate progress in the getter method
        get {
            if (tasks.Count == 0) return 0; 
            int tasksCompleted = tasks.Count(t => t.IsCompleted); 
            return (tasksCompleted * 100) / tasks.Count; 
        }
        @* set => _progress = value; // actually, do not set  *@
    }

    private IEnumerable<TaskItem> FilteredTasks => filterTasks switch 
        // to iterate over 
        {
            TaskFilter.ViewAll => tasks, 
            TaskFilter.ViewCompleted => tasks.Where(t => t.IsCompleted), 
            TaskFilter.ViewPending => tasks.Where(t => !t.IsCompleted), 
            _ => tasks
        };

    @* -------------------------------------------------- *@
    
    // Add Task upon Keydown 
    private async Task HandleKeyPress(KeyboardEventArgs e){
        if (e.Key == "Enter") {
            await AddTask(); 
        }
    }
    // Save to localStorage 
    private async Task SaveTasksToLocalStorage() {
        try {
            await JS.InvokeVoidAsync("localStorage.setItem", "tasks", JsonSerializer.Serialize(tasks)); 
        } catch (Exception e) {
            Console.WriteLine($"Error saving to localStorage: {e.Message}");
        }
    }

    private async Task AddTask() {
        if (!string.IsNullOrWhiteSpace(taskInput)) {
            tasks.Add(new TaskItem { Text = taskInput, IsCompleted = false }); 
            // TO DO save to localStorage
            await SaveTasksToLocalStorage(); 
            taskInput = ""; 
            StateHasChanged(); 
        }
    }

    private async Task ToggleComplete(TaskItem task) {
        task.IsCompleted = ! task.IsCompleted; 
        await SaveTasksToLocalStorage(); 
        StateHasChanged(); 
    }
    private async Task DeleteTask(TaskItem task) {
        // delete 
        tasks.Remove(task); 
        await SaveTasksToLocalStorage(); 
        StateHasChanged(); 
    }

    // Load the list containing tasks - "tasks" from localStorage 
    // Create a new list otherwise 
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
           string? json = await JS.InvokeAsync<string?>("localStorage.getItem", "tasks");
            if (json != null) {
                try {
                    tasks = JsonSerializer.Deserialize<List<TaskItem>>(json) ?? new(); 
                } catch (JsonException) {
                    tasks = new(); // new list if json is corrupted 
                    await SaveTasksToLocalStorage();
                }
                
            }
            StateHasChanged(); 
        }
        
    }  

}