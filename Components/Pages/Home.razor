@page "/"
@using System.Threading.Tasks
@using System.Text.Json
@using Microsoft.AspNetCore.Mvc
@rendermode InteractiveServer 
@inject IJSRuntime JS 

<PageTitle>Home</PageTitle>

<h1>To Do App</h1>

<section class="input-section">
    <p>Please enter a task below to get going.</p>
    <label for="text-input">Add New Task</label> 
    <input @bind="taskInput" class="form-control" placeholder="Enter a task" type="text" name="text-input" id="text-input">
    <button class="btn btn-outline-secondary" @onclick="AddTask">Add Task</button><br />
    
    <label for="filter-tasks">Filter Tasks</label>
    <select @bind="filterTasks" class="form-select" name="filter-tasks" id="filter-tasks">
    <option value="ViewAll">View All Tasks</option>
    <option value="ViewPending">View Pending</option>
    <option value="ViewCompleted">View Completed</option>
    </select>
</section>

<section class="output-section">
    <div class="progress-container">
        <div class="progress">
            <div class="progress-bar" role="progressbar" style="width: @progress%" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
    </div>

    @* @if (filterTasks == null || filterCompletedTasks == null) *@

   
    <ul class="task-list">
        @foreach (TaskItem task in FilteredTasks)
        {
            <li class="task-item">
                <p> <span class="@(task.IsCompleted ? "completed" : "pending")"> @task.Text</span></p>
                <div class="task-actions">
                        <button class="btn btn-outline-danger tskbtn" @onclick="() => DeleteTask(task)">Delete ✖️</button> 
                        <button class="btn btn-outline-dark tskbtn" @onclick="() => ToggleComplete(task)">Toggle completed ✔️</button>
                    </div>
            </li>
        }
    </ul>
      
      @* @if (filterTasks == TaskFilter.ViewPending) {
        @foreach(TaskItem task in tasks) 
        {
            if (!task.IsCompleted) 
            {
                 <li class="task-item">
